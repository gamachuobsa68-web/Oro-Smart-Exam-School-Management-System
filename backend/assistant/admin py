from django.contrib import admin


from .models import AssistantRequest





@admin.register(AssistantRequest)
class AssistantRequestAdmin(admin.ModelAdmin):


    list_display = (

        "user",

        "request_type",

        "created_at"

    )


    search_fields = (

        "user__username",

        "prompt"

    )


    list_filter = (

        "request_type",

        "created_at"

    )


    readonly_fields = (

        "created_at",

    )
