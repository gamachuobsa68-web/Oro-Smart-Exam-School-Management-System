<LoginScreen>:

    BoxLayout:
        orientation: "vertical"
        padding: 30
        spacing: 20


        Label:
            text: "Oro Smart Exam"
            font_size: 28
            size_hint_y: 0.3


        TextInput:
            id: username
            hint_text: "Username"
            multiline: False


        TextInput:
            id: password
            hint_text: "Password"
            password: True
            multiline: False


        Button:
            text: "LOGIN"
            size_hint_y: 0.2
            on_press: root.login_user()


        Label:
            id: message
            text: ""
            color: 1,0,0,1





<HomeScreen>:

    BoxLayout:
        orientation: "vertical"
        padding: 20
        spacing: 15


        Label:
            text: "Student Dashboard"
            font_size: 26
            size_hint_y: 0.2


        ScrollView:

            Label:
                id: exam_list
                text: "Loading exams..."
                size_hint_y: None
                height: self.texture_size[1]


        Button:
            text: "Refresh Exams"
            size_hint_y: 0.2
            on_press: root.on_pre_enter()


        Button:
            text: "Logout"
            size_hint_y: 0.2
            on_press: app.stop()
