<LoginScreen>:
    name: "login"

    BoxLayout:
        orientation: "vertical"
        padding: 30
        spacing: 20

        Label:
            text: "Oro Smart Exam System"
            font_size: 28

        TextInput:
            id: username
            hint_text: "Username"
            multiline: False

        TextInput:
            id: password
            hint_text: "Password"
            password: True
            multiline: False

        Button:
            text: "LOGIN"
            size_hint_y: 0.3
            on_press: root.login()


<HomeScreen>:
    name: "home"

    BoxLayout:
        orientation: "vertical"
        padding: 30
        spacing: 20

        Label:
            text: "Student Dashboard"
            font_size: 28

        Button:
            text: "View Exams"

        Button:
            text: "My Results"

        Button:
            text: "Logout"
            on_press: app.stop()
